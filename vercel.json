{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/vocabulary-memory-app/browser",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5"
    }
  }
}
